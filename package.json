{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore --project demo-scriptally-test 'npx vitest run --config vitest.config.rules.ts'",
    "check:derivation": "esbuild scripts/derivationCheck.ts --bundle --platform=node --outfile=/tmp/derivationCheck.cjs && node /tmp/derivationCheck.cjs",
    "deploy:rules:dryrun": "firebase deploy --only firestore:rules --dry-run --project prod",
    "deploy:rules": "firebase deploy --only firestore:rules --project prod",
    "deploy:hosting": "npm run build && firebase deploy --only hosting --project prod",
    "deploy:dev": "firebase deploy --project dev"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "firebase-tools": "^15.22.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.2.6"
  }
}
